# ── Dependencies ──────────────────────────────────────────
node_modules/
.pnp
.pnp.js
bun.lockb

# ── Build outputs ─────────────────────────────────────────
.next/
out/
dist/
dist-ssr/
build/
.output/
.vercel/

# ── Environment files (never commit secrets) ──────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
# Allow .env.example files (they contain no secrets)
!*.env.example

# ── Python ────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
venv/
.venv/
*.egg-info/

# ── Editor / OS ───────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo

# ── Logs ─────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Misc ─────────────────────────────────────────────────
.turbo/
.cache/
*.tsbuildinfo
